{
  "name": "@isonia/sdk",
  "version": "0.8.0-alpha.1",
  "description": "Pure TypeScript SDK for IsoniaOS Control Plane REST APIs",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./activation-batch": {
      "types": "./dist/activation-batch.d.ts",
      "default": "./dist/activation-batch.js"
    },
    "./control-plane-paths": {
      "types": "./dist/control-plane-paths.d.ts",
      "default": "./dist/control-plane-paths.js"
    },
    "./finalization": {
      "types": "./dist/finalization.d.ts",
      "default": "./dist/finalization.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "tsc -p tsconfig.json",
    "test": "pnpm build && node --test test/control-plane-paths.test.cjs test/activation-batch.test.cjs test/finalization.test.cjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@isonia/types": "github:isoniaos/types#v0.8.0-alpha.1"
  },
  "devDependencies": {
    "typescript": "5.7.3"
  },
  "engines": {
    "node": ">=22"
  }
}
